{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "actions": [
    {
      "command": "openNewTabDropdown"
    },
    {
      "command": {
        "action": "copy",
        "singleLine": false
      },
      "keys": "ctrl+c"
    },
    {
      "command": "paste",
      "keys": "ctrl+v"
    },
    {
      "command": "duplicateTab"
    },
    {
      "command": "find",
      "keys": "ctrl+f"
    },
    {
      "command": "unbound",
      "keys": "ctrl+shift+d"
    },
    {
      "command": "unbound",
      "keys": "alt+shift+d"
    },
    {
      "command": "unbound",
      "keys": "ctrl+shift+f"
    },
    {
      "command": "unbound",
      "keys": "ctrl+shift+t"
    },
    {
      "command": "unbound",
      "keys": "ctrl+j"
    },
    {
      "command": {
        "action": "splitPane",
        "split": "auto",
        "splitMode": "duplicate"
      }
    },
    {
      "command": {
        "action": "nextTab"
      }
    },
    {
      "command": {
        "action": "clearBuffer",
        "clear": "all"
      },
      "keys": "ctrl+l"
    },
    {
      "command": {
        "action": "closeTab"
      },
      "keys": "alt+j"
    },
    {
      "command": {
        "action": "newTab"
      },
      "keys": "ctrl+shift+j"
    }
  ],
  "confirmCloseAllTabs": false,
  "copyFormatting": "none",
  "copyOnSelect": false,
  "defaultProfile": "{106e7786-90ca-4307-b2e8-7bff52e400dc}",
  "newTabMenu": [
    {
      "type": "remainingProfiles"
    }
  ],
  "profiles": {
    "defaults": {
      "backgroundImage": null,
      "colorScheme": "OnnoKicu",
      "font": {
        "face": "Fira Code",
        "size": 11.0
      },
      "opacity": 100,
      "padding": "5",
      "scrollbarState": "hidden",
      "useAcrylic": false
    },
    "list": [
      {
        "commandline": "C:/Program Files/Git/bin/bash.exe -i -l",
        "guid": "{106e7786-90ca-4307-b2e8-7bff52e400dc}",
        "hidden": false,
        "icon": "E:/WindowsTerminal/ProfileIcons/bash.png",
        "name": "Bash"
      },
      {
        "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
        "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
        "hidden": false,
        "name": "Windows PowerShell"
      },
      {
        "commandline": "%SystemRoot%\\System32\\cmd.exe",
        "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
        "hidden": false,
        "name": "Command Prompt"
      }
    ]
  },
  "schemes": [
    {
      "background": "#21252C",
      "black": "#3f4451",
      "blue": "#4aa5f0",
      "brightBlack": "#4f5666",
      "brightBlue": "#4dc4ff",
      "brightCyan": "#4cd1e0",
      "brightGreen": "#a5e075",
      "brightPurple": "#C678DD",
      "brightRed": "#ff616e",
      "brightWhite": "#e6e6e6",
      "brightYellow": "#f0a45d",
      "cursorColor": "#FFFFFF",
      "cyan": "#42b3c2",
      "foreground": "#abb2bf",
      "green": "#8cc265",
      "name": "OnnoKicu",
      "purple": "#C678DD",
      "red": "#e05561",
      "selectionBackground": "#FFFFFF",
      "white": "#d7dae0",
      "yellow": "#d18f52"
    }
  ],
  "showTabsInTitlebar": true,
  "theme": "system",
  "themes": [
    {
      "name": "legacyDark",
      "tab": {
        "background": null,
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "window": {
        "applicationTheme": "dark",
        "useMica": false
      }
    },
    {
      "name": "legacyLight",
      "tab": {
        "background": null,
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "window": {
        "applicationTheme": "light",
        "useMica": false
      }
    },
    {
      "name": "legacySystem",
      "tab": {
        "background": null,
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "window": {
        "applicationTheme": "system",
        "useMica": false
      }
    }
  ],
  "useAcrylicInTabRow": false,
  "windowingBehavior": "useExisting"
}
