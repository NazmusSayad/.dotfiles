[
  // Shell Configs
  {
    "Source": "@/config/shell/bash-config.sh",
    "Target": "~/.bashrc"
  },
  {
    "Source": "@/config/shell/fish-config.fish",
    "Target": "~/.config/fish/config.fish"
  },
  {
    "Source": "@/config/shell/zsh-config.sh",
    "Target": "~/.zshrc"
  },
  {
    "Source": "@/config/shell/powershell.ps1",
    "Target.Win": [
      "~/Documents/PowerShell/profile.ps1",
      "~/Documents/PowerShell/Microsoft.PowerShell_profile.ps1",
      "~/Documents/WindowsPowerShell/Microsoft.PowerShell_profile.ps1"
    ]
  },

  // Agent Configs
  {
    "Source": "@/config/ai/README_AGENTS.md",
    "Target": ["~/.config/opencode/AGENTS.md", "~/.codex/AGENTS.md"]
  },
  {
    "Source": "@/config/ai/skills",
    "Target": ["~/.agents/skills", "~/.claude/skills", "~/.claude-work/skills"]
  },
  {
    "Source": "@/config/ai/commands",
    "Target": [
      "~/.claude/commands",
      "~/.claude-work/commands",
      "~/.config/opencode/commands"
    ]
  },
  {
    "Source": "@/config/ai/opencode.json",
    "Target": "~/.config/opencode/config.json"
  },
  {
    "Source": "@/config/ai/opencode-tui.json",
    "Target": "~/.config/opencode/tui.json"
  },
  {
    "Source": "@/config/ai/agents",
    "Target": "~/.config/opencode/agents"
  },
  {
    "Source": "@/config/ai/themes",
    "Target": "~/.config/opencode/themes"
  },
  {
    "Source": "@/config/ai/plugins",
    "Target": "~/.config/opencode/plugins"
  },
  {
    "Source": "@/config/ai/opencode-armor.json",
    "Target": "~/.opencode-armor.json"
  },
  {
    "Source": "@/config/ai/t3code.jsonc",
    "Target": "~/.t3/userdata/settings.json"
  },
  {
    "Source": "@/config/ai/t3code.jsonc",
    "Target": "~/.t3/userdata/keybindings.json"
  },
  {
    "Source": "@/config/ai/t3client.jsonc",
    "Target": "~/.t3/userdata/client-settings.json"
  },

  // Claude
  {
    "Source": "@/config/ai/README_CLAUDE.md",
    "Target": ["~/.claude-work/CLAUDE.md", "~/.claude/CLAUDE.md"]
  },
  {
    "Source": "@/config/ai/claude.jsonc",
    "Target": ["~/.claude/settings.json", "~/.claude-work/settings.json"]
  },
  {
    "Source": "~/.claude/plans",
    "Target": "~/.claude-work/plans"
  },
  {
    "Source": "~/.claude/tasks",
    "Target": "~/.claude-work/tasks"
  },
  {
    "Source": "~/.claude/projects",
    "Target": "~/.claude-work/projects"
  },
  {
    "Source": "~/.claude/sessions",
    "Target": "~/.claude-work/sessions"
  },
  {
    "Source": "~/.claude/session-env",
    "Target": "~/.claude-work/session-env"
  },
  {
    "Source": "~/.claude/history.jsonl",
    "Target": "~/.claude-work/history.jsonl"
  },

  // Opencode Local Configs
  {
    "Source": "@/.local/opencode-desktop.dat",
    "Target.Win": "$APPDATA/ai.opencode.desktop/default.dat",
    "Target.Mac": "~/Library/Application Support/ai.opencode.desktop/default.dat"
  },
  {
    "Source": "@/.local/opencode-auth.json",
    "Target": "~/.local/share/opencode/auth.json"
  },

  // Terminal Configs
  {
    "Source": "@/config/shell/alias.yaml",
    "Target": "~/.config/shaka.yaml"
  },
  {
    "Source": "@/config/shell/starship.toml",
    "Target": "~/.config/starship.toml"
  },
  {
    "Source": "@/config/shell/direnv.toml",
    "Target": "~/.config/direnv/direnv.toml"
  },
  {
    "Source": "@/config/mise-config.toml",
    "Target": "~/.config/mise/config.toml"
  },
  {
    "Source": "@/config/shell/fastfetch.jsonc",
    "Target": "~/.config/fastfetch/config.jsonc"
  },
  {
    "Source": "@/config/shell/btop.conf",
    "Target": "~/.config/btop/btop.conf"
  },
  {
    "Source": "@/config/shell/lsd-config.yaml",
    "Target": "~/.config/lsd/config.yaml"
  },
  {
    "Source": "@/config/windows-terminal.json",
    "Target.Win": "$LOCALAPPDATA/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"
  },
  {
    "Source": "@/config/shell/ghostty.conf",
    "Target.Mac": "~/.config/ghostty/config"
  },

  // Other Configs
  {
    "Source": "@/config/obs/basic",
    "Target.Win": "$APPDATA/obs-studio/basic"
  },
  {
    "Source": "@/config/obs/user.ini",
    "Target.Win": "$APPDATA/obs-studio/user.ini"
  },
  {
    "Source": "@/config/obs/basic-mac",
    "Target.Mac": "~/Library/Application Support/obs-studio/basic"
  },
  {
    "Source": "@/config/obs/user-mac.ini",
    "Target.Mac": "~/Library/Application Support/obs-studio/user.ini"
  },
  {
    "Source": "@/config/keymap.mac.json",
    "Target.Mac": "~/.config/karabiner/assets/complex_modifications/keymap.json"
  },
  {
    "Source": "@/config/ai/codex-pets",
    "Target": "~/.codex/pets"
  },
  {
    "Source": "@/config/oiper.json",
    "Target": "~/.oiper/config.json"
  },
  {
    "Source": "@/config/uni-run.json",
    "Target": "~/.uni-run.json"
  },
  {
    "Source": "@/config/nirc",
    "Target": "~/.nirc"
  },

  // Code Editor
  {
    "Source": "@/config/vscode/snippets",
    "Target.Win": ["$APPDATA/Code/User/snippets"],
    "Target.Mac": ["~/Library/Application Support/Code/User/snippets"]
  },
  {
    "Source": "@/config/vscode/settings.jsonc",
    "Target.Win": ["$APPDATA/Code/User/settings.json"],
    "Target.Mac": ["~/Library/Application Support/Code/User/settings.json"]
  },
  {
    "Source": "@/config/vscode/keybindings.jsonc",
    "Target.Win": ["$APPDATA/Code/User/keybindings.json"]
  },
  {
    "Source": "@/config/vscode/mac-keybindings.jsonc",
    "Target.Mac": ["~/Library/Application Support/Code/User/keybindings.json"]
  }
]
