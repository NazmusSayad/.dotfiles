{
  "startOnLogin": true,
  "whisperBackend": "auto",

  "words": ["Nazmus Sayad"],

  "cloudASRs": [
    {
      "id": "groq-whisper",
      "model": "whisper-large-v3",
      "apiUrl": "https://api.groq.com/openai/v1",
      "apiKeyEnv": "GROQ_API_KEY"
    }
  ],

  "cloudLLMs": [
    {
      "id": "openrouter-gpt-oss",
      "model": "openai/gpt-oss-120b:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    },
    {
      "id": "openrouter-audio-gemini",
      "model": "google/gemini-2.5-flash-lite:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    },
    {
      "id": "openrouter-audio-mimo",
      "model": "xiaomi/mimo-v2.5:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    }
  ],

  "profiles": [
    {
      "id": "basic-profile",
      "name": "Basic",

      "hotkey": "F14",
      "language": "en",

      "mode": "cloud",
      "transcribeAsrModel": "base.en",
      "transcribeAsrId": "groq-whisper",
      "enhancementLlmId": "openrouter-gpt-oss"
    },
    {
      "id": "formal-profile",
      "name": "Formal",

      "hotkey": "Shift+F14",
      "language": "en",

      "mode": "cloud",
      "transcribeAsrModel": "base.en",
      "transcribeAsrId": "groq-whisper",
      "enhancementType": "formal",
      "enhancementLlmId": "openrouter-gpt-oss"
    },
    {
      "id": "prompt-profile",
      "name": "Prompt",

      "hotkey": "Ctrl+F14",
      "language": "en",

      "mode": "cloud",
      "transcribeAsrModel": "base.en",
      "transcribeAsrId": "groq-whisper",
      "enhancementType": "prompt",
      "enhancementLlmId": "openrouter-gpt-oss"
    }
  ]
}
