{
  "startOnLogin": true,
  "whisperBackend": "auto",

  "words": ["Nazmus Sayad"],

  "cloudASRs": [
    {
      "id": "groq-whisper",
      "model": "whisper-large-v3",
      "apiUrl": "https://api.groq.com/openai/v1",
      "apiKeyEnv": "GROQ_API_KEY"
    }
  ],

  "cloudLLMs": [
    {
      "id": "openrouter-gpt-oss",
      "model": "openai/gpt-oss-120b:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    },
    {
      "id": "openrouter-audio-1",
      "model": "qwen/qwen3.5-35b-a3b:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    },
    {
      "id": "openrouter-audio-2",
      "model": "mistralai/mistral-medium-3:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    },
    {
      "id": "openrouter-audio-3",
      "model": "amazon/nova-lite-v1:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    }
  ],

  "profiles": [
    {
      "id": "main-profile",
      "name": "Main",
      "mode": "cloud",
      "hotkey": "F14",
      "language": "en",
      "transcribeAsrModel": "base.en",
      "enhancementLlmId": "openrouter-gpt-oss",
      "transcribeLlmId": "openrouter-audio-1",
      "enhancementType": "prompt"
    }
  ]
}
