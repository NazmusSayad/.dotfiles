{
  "startOnLogin": true,
  "whisperBackend": "auto",

  "words": ["Nazmus Sayad"],

  "cloudASRs": [
    {
      "id": "groq-whisper",
      "model": "whisper-large-v3",
      "apiUrl": "https://api.groq.com/openai/v1",
      "apiKeyEnv": "GROQ_API_KEY"
    }
  ],

  "cloudLLMs": [
    {
      "id": "openrouter-gpt-oss",
      "model": "openai/gpt-oss-120b:nitro",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    },
    {
      "id": "openrouter-mistral-audio",
      "model": "mistralai/voxtral-small-24b-2507",
      "apiUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    }
  ],

  "profiles": [
    {
      "id": "main-profile",
      "name": "Main",
      "hotkey": "F14",
      "language": "en",

      "mode": "cloud",

      "transcribeAsrModel": "base.en",
      "transcribeLlmId": "openrouter-mistral-audio",

      "enhancementType": "prompt",
      "enhancementLlmId": "openrouter-gpt-oss"
    }
  ]
}
