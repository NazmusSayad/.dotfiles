{
  "writeClipboard": false,
  "injectionMethod.macos": "Ctrl+V",
  "injectionMethod.windows": "Ctrl+V",
  "pasteLastHotkey.macos": "Ctrl+Alt+Enter",
  "pasteLastHotkey.windows": "Ctrl+Insert",

  "cloudASRs": [
    {
      "id": "groq-whisper",
      "model": "whisper-large-v3",
      "provider": "groq"
    },
    {
      "id": "openrouter-whisper",
      "model": "openai/whisper-large-v3",
      "provider": "openrouter"
    }
  ],

  "cloudLLMs": [
    {
      "id": "openrouter-nano",
      "model": "openai/gpt-oss-20b:nitro",
      "provider": "openrouter"
    },
    {
      "id": "openrouter-mini",
      "model": "openai/gpt-oss-120b:nitro",
      "provider": "openrouter"
    }
  ],

  "words": ["NazmusSayad", "OiPer"],

  "snippets": {
    "My GitHub": "https://github.com/NazmusSayad",
    "My Website": "https://nazmussayad.com"
  },

  "profiles": [
    {
      "id": "basic-profile",
      "name": "Basic",
      "icon": "VoiceIcon",
      "hotkey.macos": "ShiftLeft+ControlLeft",
      "hotkey.windows": "ShiftLeft+ControlLeft",
      "language": "en",
      "mode": "cloud",
      "transcribeAsrId": "groq-whisper",
      "enhancementLlmId": "openrouter-nano",
      "transcribeAsrModel": "medium.en"
    },
    {
      "id": "normal-profile",
      "name": "Normal",
      "icon": "AiContentGenerator02Icon",
      "hotkey.macos": "ShiftLeft+Alt",
      "hotkey.windows": "ShiftLeft+Alt",
      "language": "en",
      "mode": "cloud",
      "transcribeAsrId": "groq-whisper",
      "enhancementLlmId": "openrouter-mini",
      "enhancementType": "normal"
    },
    {
      "id": "prompt-profile",
      "name": "Prompt",
      "icon": "AiProgrammingIcon",
      "hotkey.macos": "ShiftLeft+MetaLeft",
      "hotkey.windows": "ControlLeft+MetaLeft",
      "language": "en",
      "mode": "cloud",
      "transcribeAsrId": "groq-whisper",
      "enhancementLlmId": "openrouter-mini",
      "enhancementType": "prompt"
    }
  ]
}
