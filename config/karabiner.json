{
  "global": {
    "ask_for_confirmation_before_quitting": false,
    "check_for_updates_on_startup": false,
    "enable_notification_window": false,
    "filter_useless_events_from_specific_devices": false,
    "reorder_same_timestamp_input_events_to_prioritize_modifiers": false,
    "show_in_menu_bar": false
  },
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          {
            "description": "Option+Space → Option+Shift+F",
            "manipulators": [
              {
                "from": {
                  "key_code": "spacebar",
                  "modifiers": { "mandatory": ["option"] }
                },
                "to": [
                  {
                    "key_code": "f",
                    "modifiers": ["option", "shift"]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "CapsLock -> Spotlight",
            "manipulators": [
              {
                "from": {
                  "key_code": "caps_lock",
                  "modifiers": { "optional": ["any"] }
                },
                "to": [
                  {
                    "key_code": "spacebar",
                    "modifiers": ["left_command"]
                  }
                ],
                "type": "basic"
              }
            ]
          }
        ]
      },
      "name": "Default",
      "selected": true,
      "virtual_hid_keyboard": {
        "indicate_sticky_modifier_keys_state": false,
        "keyboard_type_v2": "ansi"
      }
    }
  ]
}
