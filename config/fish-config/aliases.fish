alias gs="git status"
alias grs="git restore"
alias grh="git reset --hard"

alias gp="git pull"
alias gb="git branch"
alias gc="git checkout"

alias cl="gh repo clone"
alias gv="gh repo view"

alias pa="php artisan"
alias pas="php artisan serve"

alias r="npm run"
alias nx="npm exec"
alias ni="npm install"
alias nu="npm uninstall"
