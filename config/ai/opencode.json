{
  "lsp": false,
  "plugin": ["opencode-wakatime"],

  "permission": {
    "doom_loop": "allow",
    "external_directory": {
      "~/Desktop/**": "allow",
      "~/AppData/Local/Pub/Cache/**": "allow"
    }
  },

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    },

    "hugeicons": {
      "type": "local",
      "enabled": false,
      "command": ["hugeicons-mcp"]
    }
  },

  "small_model": "openrouter/openrouter/free",

  "enabled_providers": [],

  "provider": {},

  "share": "disabled",
  "logLevel": "ERROR",
  "autoshare": false,
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json"
}
