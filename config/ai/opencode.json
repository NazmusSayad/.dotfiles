{
  "lsp": false,
  "shell": "bash",
  "permission": "allow",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "small_model": "opencode/deepseek-v4-flash-free",
  "agent": {
    "explore": { "model": "opencode/deepseek-v4-flash-free" },
    "general": { "disable": true },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "options": {
        "provider": { "sort": "throughput" },
        "reasoning": { "effort": "low" }
      }
    }
  },

  "enabled_providers": ["opencode", "opencode-go", "openrouter", "xai"],
  "provider": {
    "opencode": {
      "whitelist": ["deepseek-v4-flash-free"]
    },
    "opencode-go": {
      "whitelist": []
    },
    "openrouter": {
      "whitelist": ["deepseek/deepseek-v4-pro","moonshotai/kimi-k2.6","openai/gpt-oss-120b"]
    },
    "xai": {
      "whitelist": ["grok-build-0.1"]
    }
  },

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "$schema": "https://opencode.ai/config.json"
}
