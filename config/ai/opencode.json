{
  "lsp": false,
  "snapshot": false,

  "shell": "bash",
  "permission": {
    "*": "allow",
    "lsp": "deny",
    "doom_loop": "deny"
  },

  "plugin": ["opencode-armor@latest", "opencode-wakatime@latest"],

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "command": {
    "ask": {
      "agent": "ask",
      "description": "Answers questions, discusses context, and provides information",
      "template": ""
    },
    "plan": {
      "agent": "plan",
      "description": "Creates a plan about how to solve the problem",
      "template": ""
    },
    "x": {
      "agent": "build",
      "description": "Follow the plan and start building",
      "template": ""
    }
  },

  "small_model": "opencode/deepseek-v4-flash-free",
  "agent": {
    "general": { "disable": true },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "deny",
        "lsp": "deny",
        "question": "deny",
        "task": "deny",
        "write": "deny"
      }
    },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "options": {
        "provider": { "sort": "throughput" },
        "reasoning": { "effort": "low" }
      }
    }
  },

  "enabled_providers": ["opencode", "openrouter", "xai"],
  "provider": {
    "opencode": { "whitelist": ["deepseek-v4-flash-free", "minimax-m3-free"] },
    "openrouter": {
      "whitelist": ["moonshotai/kimi-k2.6", "openai/gpt-oss-120b"],
      "models": {
        "moonshotai/kimi-k2.6": {
          "attachment": true,
          "cost": { "cache_read": 0.144, "input": 0.684, "output": 3.42 },
          "family": "kimi-k2.6",
          "id": "moonshotai/kimi-k2.6",
          "limit": { "context": 262144, "output": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "Kimi K2.6",
          "options": { "provider": { "only": ["fireworks"] } },
          "reasoning": true,
          "release_date": "2026-04-21",
          "temperature": true,
          "tool_call": true
        }
      }
    },
    "xai": { "whitelist": ["grok-build-0.1"] }
  },

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "logLevel": "DEBUG",
  "$schema": "https://opencode.ai/config.json"
}
