{
  "lsp": false,
  "shell": "bash",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "permission": {
    "doom_loop": "allow",
    "external_directory": {
      "~/Desktop/**": "allow",
      "~/.cargo/registry/**": "allow",
      "~/AppData/Local/Pub/Cache/**": "allow"
    }
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    },
    "hugeicons": {
      "type": "local",
      "enabled": false,
      "command": ["hugeicons-mcp"]
    }
  },

  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "general": { "model": "opencode-go/deepseek-v4-pro" },
    "explore": { "model": "opencode-go/deepseek-v4-pro" }
  },

  "enabled_providers": ["openai", "opencode", "opencode-go"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "attachment": true,
          "cost": {
            "cache_read": 0.175,
            "input": 1.75,
            "output": 14
          },
          "family": "gpt-codex",
          "id": "gpt-5.3-codex",
          "limit": {
            "context": 256000,
            "input": 256000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "name": "GPT-5.3 Codex",
          "reasoning": true,
          "release_date": "2026-02-05",
          "temperature": false,
          "tool_call": true
        },
        "gpt-5.5": {
          "attachment": true,
          "cost": {
            "cache_read": 0.5,
            "input": 5,
            "output": 30
          },
          "family": "gpt",
          "id": "gpt-5.5",
          "limit": {
            "context": 256000,
            "input": 256000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "name": "GPT-5.5",
          "reasoning": true,
          "release_date": "2026-04-23",
          "temperature": false,
          "tool_call": true
        },
        "gpt-5.4-mini": {
          "attachment": true,
          "cost": { "cache_read": 0.075, "input": 0.75, "output": 4.5 },
          "family": "gpt-mini",
          "id": "gpt-5.4-mini",
          "limit": { "context": 256000, "input": 256000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "GPT-5.4 mini",
          "reasoning": true,
          "release_date": "2026-03-17",
          "temperature": false,
          "tool_call": true
        }
      },
      "whitelist": ["gpt-5.3-codex", "gpt-5.4-mini", "gpt-5.5"]
    },
    "opencode": {
      "whitelist": ["minimax-m2.5-free"]
    },
    "opencode-go": {
      "whitelist": ["deepseek-v4-pro", "glm-5.1", "kimi-k2.6"]
    }
  },

  "share": "disabled",
  "logLevel": "ERROR",
  "autoshare": false,
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json"
}
