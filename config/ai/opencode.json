{
  "lsp": false,
  "shell": "bash",
  "permission": "allow",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "general": { "disable": true },
    "title": { "model": "cerebras/gpt-oss-120b" },
    "explore": { "model": "opencode/deepseek-v4-flash-free" }
  },

  "enabled_providers": ["cerebras", "opencode", "opencode-go"],
  "provider": {
    "cerebras": {
      "whitelist": ["gpt-oss-120b"]
    },
    "opencode": {
      "whitelist": ["deepseek-v4-flash-free", "minimax-m2.5-free"]
    },
    "opencode-go": {
      "whitelist": ["deepseek-v4-pro", "glm-5.1", "kimi-k2.6", "mimo-v2.5-pro"]
    }
  },

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "$schema": "https://opencode.ai/config.json"
}
