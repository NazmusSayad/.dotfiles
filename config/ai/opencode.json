{
  "experimental": {
    "continue_loop_on_deny": true
  },

  // "model": "openai/gpt-5.3-codex",
  "model": "github-copilot/gpt-5.3-codex",

  "enabled_providers": ["github-copilot", "openai", "fireworks+", "kilo+"],

  "provider": {
    "github-copilot": {
      "whitelist": ["gpt-5.3-codex"]
    },

    "openai": {
      "whitelist": ["gpt-5.3-codex", "gpt-5.4"]
    }
  },

  "plugin": ["opencode-wakatime"],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "username": "Sayad",

  "share": "disabled",
  "autoshare": false,
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json"
}
