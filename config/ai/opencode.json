{
  "lsp": false,
  "shell": "bash",
  "permission": "allow",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "general": { "disable": true },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "reasoning": { "effort": "minimal" },
      "provider": { "sort": "throughput" }
    },
    "explore": { "model": "opencode/deepseek-v4-flash-free" }
  },

  "enabled_providers": ["opencode", "opencode-go", "openrouter"],
  "provider": {
    "opencode": {
      "whitelist": ["deepseek-v4-flash-free", "minimax-m2.5-free"]
    },
    "opencode-go": {
      "whitelist": ["deepseek-v4-pro", "glm-5.1", "kimi-k2.6", "mimo-v2.5-pro"]
    },
    "openrouter": {
      "models": {
        "openai/gpt-oss-120b": {
          "attachment": false,
          "cost": { "input": 0.039, "output": 0.18 },
          "family": "gpt-oss",
          "id": "openai/gpt-oss-120b",
          "limit": { "context": 131072, "output": 32768 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "gpt-oss-120b",
          "reasoning": true,
          "release_date": "2025-08-05",
          "temperature": true,
          "tool_call": true
        }
      },
      "whitelist": ["openai/gpt-oss-120b"]
    }
  },

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "$schema": "https://opencode.ai/config.json"
}
