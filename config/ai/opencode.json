{
  "lsp": false,
  "snapshot": false,

  "shell": "bash",
  "permission": "allow",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "command": {
    "ask": {
      "agent": "ask",
      "description": "Answers questions, discusses context, and provides information",
      "template": ""
    },
    "plan": {
      "agent": "plan",
      "description": "Creates a plan about how to solve the problem",
      "template": ""
    },
    "x": {
      "agent": "build",
      "description": "Follow the plan and start building",
      "template": ""
    }
  },

  "small_model": "opencode/deepseek-v4-flash-free",
  "agent": {
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "deny",
        "lsp": "deny",
        "question": "deny",
        "task": "deny",
        "write": "deny"
      }
    },
    "general": {
      "permission": { "lsp": "deny", "question": "deny", "task": "deny" }
    },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "options": {
        "provider": { "sort": "throughput" },
        "reasoning": { "effort": "low" }
      }
    }
  },

  "enabled_providers": ["opencode", "openrouter", "xai"],
  "provider": {
    "opencode": { "whitelist": ["deepseek-v4-flash-free"] },
    "openrouter": {
      "whitelist": [
        "deepseek/deepseek-v4-pro",
        "moonshotai/kimi-k2.6",
        "openai/gpt-oss-120b",
        "z-ai/glm-5.1"
      ],
      "models": {
        "moonshotai/kimi-k2.6": {
          "attachment": true,
          "cost": { "cache_read": 0.144, "input": 0.684, "output": 3.42 },
          "family": "kimi-k2.6",
          "id": "moonshotai/kimi-k2.6",
          "limit": { "context": 262144, "output": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "Kimi K2.6",
          "options": {
            "provider": { "only": ["fireworks"], "allowFallbacks": false }
          },
          "reasoning": true,
          "release_date": "2026-04-21",
          "temperature": true,
          "tool_call": true
        },
        "deepseek/deepseek-v4-pro": {
          "attachment": false,
          "cost": { "cache_read": 0.003625, "input": 0.435, "output": 0.87 },
          "family": "deepseek-thinking",
          "id": "deepseek/deepseek-v4-pro",
          "limit": { "context": 1048576, "output": 384000 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "DeepSeek V4 Pro",
          "options": {
            "provider": { "only": ["fireworks"], "allowFallbacks": false }
          },
          "reasoning": true,
          "release_date": "2026-04-24",
          "temperature": true,
          "tool_call": true
        },
        "z-ai/glm-5.1": {
          "attachment": false,
          "cost": { "cache_read": 0.182, "input": 0.98, "output": 3.08 },
          "family": "glm",
          "id": "z-ai/glm-5.1",
          "limit": { "context": 202752, "output": 202800 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "GLM-5.1",
          "options": {
            "provider": { "only": ["fireworks"], "allowFallbacks": false }
          },
          "reasoning": true,
          "release_date": "2026-03-27",
          "temperature": true,
          "tool_call": true
        }
      }
    },
    "xai": { "whitelist": ["grok-build-0.1"] }
  },

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "logLevel": "DEBUG",
  "$schema": "https://opencode.ai/config.json"
}
