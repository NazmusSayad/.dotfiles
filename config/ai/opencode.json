{
  "lsp": false,
  "shell": "bash",
  "permission": "allow",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "explore": { "model": "opencode/deepseek-v4-flash-free" },
    "general": { "disable": true },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "options": {
        "provider": { "sort": "throughput" },
        "reasoning": { "effort": "minimal" }
      }
    }
  },

  "enabled_providers": ["opencode", "opencode-go", "openrouter"],
  "provider": {
    "opencode": {
      "whitelist": ["deepseek-v4-flash-free", "minimax-m2.5-free"]
    },
    "opencode-go": {
      "whitelist": ["deepseek-v4-pro", "glm-5.1", "kimi-k2.6", "mimo-v2.5-pro"]
    },
    "openrouter": {
      "whitelist": [
        "deepseek/deepseek-v4-pro",
        "moonshotai/kimi-k2.6",
        "openai/gpt-oss-120b"
      ]
    }
  },

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "$schema": "https://opencode.ai/config.json"
}
