{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "autoshare": false,
  "share": "disabled",

  "shell": "bash",
  "permission": {
    "*": "allow",
    "lsp": "deny",
    "doom_loop": "deny"
  },

  "lsp": false,
  "snapshot": false,
  "plugin": ["opencode-armor", "opencode-wakatime", "@dietrichgebert/ponytail"],

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "command": {
    "ask": {
      "agent": "ask",
      "description": "Answers questions, discusses context, and provides information",
      "template": ""
    },
    "plan": {
      "agent": "plan",
      "description": "Creates a plan about how to solve the problem",
      "template": ""
    },
    "x": {
      "agent": "build",
      "description": "Follow the plan and start building",
      "template": ""
    }
  },

  "agent": {
    "ask": { "color": "#89AE6E", "permission": { "edit": "deny" } },
    "build": { "color": "#C18A57" },
    "explore": {
      "color": "#ABB2BF",
      "model": "opencode-go/minimax-m3",
      "permission": { "edit": "deny", "question": "deny", "task": "deny" }
    },
    "general": {
      "color": "#D46870",
      "permission": { "question": "deny", "task": "deny" }
    },
    "plan": { "color": "#43ACB9" },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "options": {
        "provider": { "sort": "throughput" },
        "reasoning": { "effort": "medium" }
      }
    }
  },

  "enabled_providers": ["opencode", "opencode-go", "openrouter", "xai"],
  "provider": {
    "opencode": {
      "whitelist": ["deepseek-v4-flash-free", "mimo-v2.5-free"]
    },
    "opencode-go": {
      "whitelist": ["glm-5.2", "kimi-k2.7-code", "mimo-v2.5-pro", "minimax-m3"]
    },
    "openrouter": {
      "whitelist": ["openai/gpt-oss-120b"]
    },
    "xai": { "whitelist": ["grok-build-0.1"] }
  }
}
