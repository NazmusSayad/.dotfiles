{
  "lsp": false,
  "shell": "bash",
  "permission": "allow",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "small_model": "opencode/minimax-m2.5-free",
  "agent": {},

  "enabled_providers": ["opencode", "opencode-go", "openrouter"],
  "provider": {},

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "$schema": "https://opencode.ai/config.json"
}
