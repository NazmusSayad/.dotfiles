{
  "lsp": false,
  "shell": "bash",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "permission": {
    "doom_loop": "deny",
    "external_directory": "allow"
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "general": { "disable": true },
    "explore": { "model": "opencode-go/mimo-v2.5-pro" }
  },

  "enabled_providers": ["opencode", "opencode-go"],
  "provider": {
    "opencode": {
      "whitelist": [
        "deepseek-v4-flash-free",
        "minimax-m2.5-free",
        "qwen3.6-plus-free"
      ]
    },
    "opencode-go": {
      "whitelist": ["deepseek-v4-pro", "glm-5.1", "kimi-k2.6", "mimo-v2.5-pro"]
    }
  },

  "autoshare": false,
  "autoupdate": false,
  "share": "disabled",
  "$schema": "https://opencode.ai/config.json"
}
