{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "autoshare": false,
  "share": "disabled",

  "shell": "bash",
  "permission": {
    "*": "allow",
    "lsp": "deny",
    "doom_loop": "deny",
    "todowrite": "deny"
  },

  "lsp": false,
  "snapshot": false,
  "plugin": ["opencode-armor", "opencode-wakatime"],

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "command": {
    "ask": {
      "agent": "ask",
      "description": "Answers questions, discusses context, and provides information",
      "template": ""
    },
    "plan": {
      "agent": "plan",
      "description": "Creates a plan about how to solve the problem",
      "template": ""
    },
    "x": {
      "agent": "build",
      "description": "Follow the plan and start building",
      "template": ""
    }
  },

  "agent": {
    "explore": {
      "model": "opencode/nemotron-3-ultra-free",
      "permission": {
        "doom_loop": "deny",
        "edit": "deny",
        "question": "deny",
        "task": "deny"
      }
    },
    "general": {
      "disable": true,
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "task": "deny"
      }
    },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "options": {
        "provider": { "sort": "throughput" },
        "reasoning": { "effort": "medium" }
      }
    }
  },

  "enabled_providers": ["opencode", "openrouter", "xai"],
  "provider": {
    "opencode": {
      "whitelist": [
        "deepseek-v4-flash-free",
        "minimax-m3-free",
        "nemotron-3-ultra-free"
      ]
    },
    "openrouter": {
      "models": {
        "moonshotai/kimi-k2.6": {
          "attachment": true,
          "cost": { "cache_read": 0.144, "input": 0.684, "output": 3.42 },
          "family": "kimi-k2.6",
          "id": "moonshotai/kimi-k2.6",
          "limit": { "context": 262144, "output": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "Kimi K2.6",
          "options": { "provider": { "only": ["fireworks"] } },
          "reasoning": true,
          "release_date": "2026-04-21",
          "temperature": true,
          "tool_call": true
        }
      },
      "whitelist": [
        "moonshotai/kimi-k2.6",
        "nvidia/nemotron-3-ultra-550b-a55b:free",
        "openai/gpt-oss-120b"
      ]
    },
    "xai": { "whitelist": ["grok-build-0.1"] }
  }
}
