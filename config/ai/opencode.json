{
  "lsp": false,
  "shell": "C:\\msys64\\usr\\bin\\bash.exe",

  "plugin": ["opencode-armor", "opencode-wakatime"],

  "experimental": {
    "continue_loop_on_deny": true
  },

  "permission": {
    "doom_loop": "allow",
    "external_directory": {
      "~/Desktop/**": "allow",
      "~/.cargo/registry/**": "allow",
      "~/AppData/Local/Pub/Cache/**": "allow"
    }
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    },
    "hugeicons": {
      "type": "local",
      "enabled": false,
      "command": ["hugeicons-mcp"]
    }
  },

  "small_model": "opencode/minimax-m2.5-free",

  "agent": {
    "general": {
      "model": "opencode-go/kimi-k2.6"
    },
    "explore": {
      "model": "opencode-go/mimo-v2.5-pro"
    },
    "compaction": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },

  "enabled_providers": ["openai", "opencode", "opencode-go"],

  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "attachment": true,
          "cost": {
            "cache_read": 0.175,
            "input": 1.75,
            "output": 14
          },
          "family": "gpt-codex",
          "id": "gpt-5.3-codex",
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "name": "GPT-5.3 Codex",
          "reasoning": true,
          "release_date": "2026-02-05",
          "temperature": false,
          "tool_call": true
        },
        "gpt-5.5": {
          "attachment": true,
          "cost": {
            "cache_read": 0.5,
            "input": 5,
            "output": 30
          },
          "family": "gpt",
          "id": "gpt-5.5",
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "name": "GPT-5.5",
          "reasoning": true,
          "release_date": "2026-04-23",
          "temperature": false,
          "tool_call": true
        }
      },
      "whitelist": ["gpt-5.3-codex", "gpt-5.5"]
    },
    "opencode": {
      "whitelist": ["minimax-m2.5-free"]
    },
    "opencode-go": {
      "whitelist": [
        "deepseek-v4-flash",
        "deepseek-v4-pro",
        "glm-5",
        "glm-5.1",
        "kimi-k2.5",
        "kimi-k2.6",
        "mimo-v2-pro",
        "mimo-v2.5-pro",
        "minimax-m2.7"
      ]
    }
  },

  "share": "disabled",
  "logLevel": "ERROR",
  "autoshare": false,
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json"
}
