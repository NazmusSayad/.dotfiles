{
  "lsp": false,
  "plugin": ["opencode-wakatime"],

  "permission": {
    "doom_loop": "allow",
    "external_directory": {
      "~/Desktop/**": "allow",
      "~/AppData/Local/Pub/Cache/**": "allow"
    }
  },

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    },

    "hugeicons": {
      "type": "local",
      "enabled": false,
      "command": ["hugeicons-mcp"]
    }
  },

  "small_model": "openrouter/openrouter/free",

  "enabled_providers": ["openai", "openrouter", "kilo"],

  "provider": {
    "kilo": {
      "models": {
        "xiaomi/mimo-v2.5-pro": {
          "id": "xiaomi/mimo-v2.5-pro",
          "limit": { "context": 400000, "input": 400000, "output": 400000 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "Xiaomi: MiMo-V2.5-Pro"
        }
      },
      "whitelist": [
        "kilo-auto/free",
        "z-ai/glm-5.1",
        "qwen/qwen3.6-plus",
        "xiaomi/mimo-v2.5-pro",
        "moonshotai/kimi-k2.5",
        "moonshotai/kimi-k2.6",
        "minimax/minimax-m2.5",
        "minimax/minimax-m2.7"
      ]
    },
    "openai": {
      "models": {},
      "whitelist": ["gpt-5.5", "gpt-5.4", "gpt-5.3-codex"]
    },
    "openrouter": {
      "models": {
        "inclusionai/ling-2.6-1t:free": {
          "id": "inclusionai/ling-2.6-1t:free",
          "limit": { "context": 262144, "input": 262144, "output": 262144 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "inclusionAI: Ling-2.6-1T (free)"
        },
        "tencent/hy3-preview:free": {
          "id": "tencent/hy3-preview:free",
          "limit": { "context": 262144, "input": 262144, "output": 262144 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "Tencent: Hy3 preview (free)"
        }
      },
      "whitelist": [
        "openrouter/free",
        "tencent/hy3-preview:free",
        "minimax/minimax-m2.5:free",
        "inclusionai/ling-2.6-1t:free"
      ]
    }
  },

  "share": "disabled",
  "logLevel": "ERROR",
  "autoshare": false,
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json"
}
