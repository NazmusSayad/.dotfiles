{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "autoshare": false,
  "share": "disabled",

  "shell": "bash",
  "permission": {
    "*": "allow",
    "lsp": "deny",
    "doom_loop": "deny"
  },

  "lsp": false,
  "snapshot": false,
  "plugin": ["opencode-armor", "opencode-wakatime"],

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    }
  },

  "command": {
    "ask": {
      "agent": "ask",
      "description": "Answers questions, discusses context, and provides information",
      "template": ""
    },
    "plan": {
      "agent": "plan",
      "description": "Creates a plan about how to solve the problem",
      "template": ""
    },
    "x": {
      "agent": "build",
      "description": "Follow the plan and start building",
      "template": ""
    }
  },

  "agent": {
    "ask": {
      "color": "#89AE6E",
      "permission": { "edit": "deny", "task": "deny", "todowrite": "deny" }
    },
    "build": { "color": "#C18A57" },
    "explore": {
      "color": "#ABB2BF",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "deny",
        "question": "deny",
        "task": "deny",
        "todowrite": "deny"
      }
    },
    "general": {
      "color": "#D46870",
      "disable": true,
      "permission": { "question": "deny", "task": "deny" }
    },
    "plan": { "color": "#43ACB9" },
    "title": {
      "model": "openrouter/openai/gpt-oss-120b",
      "options": {
        "provider": { "sort": "throughput" },
        "reasoning": { "effort": "medium" }
      }
    }
  },

  "enabled_providers": ["opencode", "openrouter", "xai"],
  "provider": {
    "opencode": {
      "whitelist": [
        "deepseek-v4-flash-free",
        "mimo-v2.5-free",
        "nemotron-3-ultra-free"
      ]
    },
    "openrouter": {
      "models": {
        "moonshotai/kimi-k2.6": {
          "attachment": true,
          "cost": { "cache_read": 0.144, "input": 0.684, "output": 3.42 },
          "family": "kimi-k2.6",
          "id": "moonshotai/kimi-k2.6",
          "limit": { "context": 262144, "output": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "Kimi K2.6",
          "options": { "provider": { "only": ["fireworks"] } },
          "reasoning": true,
          "release_date": "2026-04-21",
          "temperature": true,
          "tool_call": true
        }
      },
      "whitelist": ["moonshotai/kimi-k2.6", "openai/gpt-oss-120b"]
    },
    "xai": { "whitelist": ["grok-build-0.1"] }
  }
}
