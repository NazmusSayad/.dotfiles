{
  "model": "openai/gpt-5.3-codex",

  "plugin": ["opencode-wakatime"],
  "enabled_providers": ["openai", "openrouter+", "kilo+"],

  "permission": {
    "doom_loop": "allow",
    "external_directory": {
      "~/Desktop/**": "allow"
    }
  },

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    },

    "hugeicons": {
      "type": "local",
      "enabled": false,
      "command": ["hugeicons-mcp"]
    }
  },

  "provider": {
    "openai": {
      "whitelist": ["gpt-5.3-codex", "gpt-5.4"]
    },

    "kilo+": {
      "name": "Kilo+",
      "api": "https://api.kilo.ai/api/gateway",
      "models": {
        "kilo-auto/free": {
          "id": "kilo-auto/free",
          "limit": {
            "context": 204800,
            "output": 204800
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Kilo Auto Free"
        },
        "minimax/minimax-m2.5": {
