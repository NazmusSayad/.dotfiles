{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "autoshare": false,
  "share": "disabled",

  "username": "Sayad",

  "plugin": ["opencode-wakatime"],
  "command": {
    "build": {
      "agent": "build",
      "description": "Follow the plan and start implementation",
      "template": "Follow the plan exactly, step by step, without changing or skipping anything.\n\n## Rules\n- No hacks. Use proven, robust approaches only.\n- If code feels fragile or wrong, fix it properly.\n- Maintain existing code style and conventions."
    }
  },

  "experimental": {
    "continue_loop_on_deny": true
  },

  "enabled_providers": ["openai", "kilo*", "openrouter*"],

  "provider": {
    "openai": {
      "whitelist": ["gpt-5.4", "gpt-5.4-mini", "gpt-5.3-codex"]
    },

    "kilo*": {
      "api": "https://api.kilo.ai/api/gateway",
      "name": "Kilo+",
      "models": {
        "MiniMax: MiniMax M2.5 (free)": {
          "id": "minimax/minimax-m2.5:free",
          "limit": {
            "context": 204800,
            "output": 204800
          },
          "name": "MiniMax: MiniMax M2.5 (free)"
        },
        "MiniMax: MiniMax M2.7": {
          "id": "minimax/minimax-m2.7",
          "limit": {
            "context": 204800,
            "output": 204800
          },
          "name": "MiniMax: MiniMax M2.7"
        },
        "MoonshotAI: Kimi K2.5": {
          "id": "moonshotai/kimi-k2.5",
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "name": "MoonshotAI: Kimi K2.5",
          "variants": {
            "instant": {
              "reasoning": {
                "enabled": false
              }
            },
            "thinking": {
              "reasoning": {
                "enabled": true
              }
            }
