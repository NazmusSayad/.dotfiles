{
  "lsp": false,
  "plugin": ["opencode-wakatime"],
  "enabled_providers": ["openai", "kilo"],

  "permission": {
    "doom_loop": "allow",
    "external_directory": {
      "~/Desktop/**": "allow"
    }
  },

  "experimental": {
    "continue_loop_on_deny": true
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": [
        "chrome-devtools-mcp",
        "--viewport=1440x900x1",
        "--headless=true"
      ]
    },

    "hugeicons": {
      "type": "local",
      "enabled": false,
      "command": ["hugeicons-mcp"]
    }
  },

  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "id": "gpt-5.3-codex",
          "name": "GPT-5.3 Codex",
          "family": "gpt-codex",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": false,
          "release_date": "2026-02-05",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "cost": { "input": 1.75, "output": 14, "cache_read": 0.175 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 }
        },
        "gpt-5.4": {
          "id": "gpt-5.4",
          "name": "GPT-5.4",
          "family": "gpt",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": false,
          "release_date": "2026-03-05",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5
            }
          },
          "limit": { "context": 1050000, "input": 922000, "output": 128000 }
        }
      }
    },
    "kilo": {
      "models": {
        "kilo-auto/free": {
          "id": "kilo-auto/free",
          "limit": { "context": 204800, "output": 204800, "input": 204800 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "Kilo Auto Free"
        },
        "minimax/minimax-m2.5": {
          "id": "minimax/minimax-m2.5",
          "limit": { "context": 196608, "output": 196608, "input": 196608 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "MiniMax: MiniMax M2.5"
        },
        "minimax/minimax-m2.7": {
          "id": "minimax/minimax-m2.7",
          "limit": { "context": 196608, "output": 196608, "input": 196608 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "MiniMax: MiniMax M2.7"
        },
        "moonshotai/kimi-k2.5": {
          "id": "moonshotai/kimi-k2.5",
          "limit": { "context": 262144, "output": 262144, "input": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "MoonshotAI: Kimi K2.5",
          "variants": {
            "instant": { "reasoning": { "effort": "none", "enabled": false } },
            "thinking": { "reasoning": { "effort": "medium", "enabled": true } }
          }
        },
        "moonshotai/kimi-k2.6": {
          "id": "moonshotai/kimi-k2.6",
          "limit": { "context": 262144, "output": 262144, "input": 262144 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "MoonshotAI: Kimi K2.6 (new)",
          "variants": {
            "instant": { "reasoning": { "effort": "none", "enabled": false } },
            "thinking": { "reasoning": { "effort": "medium", "enabled": true } }
          }
        },
        "qwen/qwen3.6-plus": {
          "id": "qwen/qwen3.6-plus",
          "limit": { "context": 1000000, "output": 1000000, "input": 1000000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "name": "Qwen: Qwen3.6 Plus",
          "variants": {
            "instant": { "reasoning": { "effort": "none", "enabled": false } },
            "thinking": { "reasoning": { "effort": "medium", "enabled": true } }
          }
        },
        "z-ai/glm-5-turbo": {
          "id": "z-ai/glm-5-turbo",
          "limit": { "context": 202752, "output": 202752, "input": 202752 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "Z.ai: GLM 5 Turbo",
          "variants": {
            "instant": { "reasoning": { "effort": "none", "enabled": false } },
            "thinking": { "reasoning": { "effort": "medium", "enabled": true } }
          }
        },
        "z-ai/glm-5.1": {
          "id": "z-ai/glm-5.1",
          "limit": { "context": 202752, "output": 202752, "input": 202752 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "name": "Z.ai: GLM 5.1",
          "variants": {
            "instant": { "reasoning": { "effort": "none", "enabled": false } },
            "thinking": { "reasoning": { "effort": "medium", "enabled": true } }
          }
        },
        "z-ai/glm-5v-turbo": {
          "id": "z-ai/glm-5v-turbo",
          "limit": { "context": 202752, "output": 202752, "input": 202752 },
          "modalities": {
            "input": ["image", "text", "video"],
            "output": ["text"]
          },
          "name": "Z.ai: GLM 5V Turbo",
          "variants": {
            "instant": { "reasoning": { "effort": "none", "enabled": false } },
            "thinking": { "reasoning": { "effort": "medium", "enabled": true } }
          }
        }
      }
    }
  },

  "share": "disabled",
  "username": "Sayad",
  "autoshare": false,
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json"
}
